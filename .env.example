# Stock API Configuration
# STOCK_API_PROVIDER=auto prefers Finnhub when FINNHUB_API_KEY/VITE_FINNHUB_API_KEY is real,
# falls back to Alpha Vantage when STOCK_API_KEY is real, and otherwise uses mock data.
# Set STOCK_API_PROVIDER=mock for tests/offline runs.
STOCK_API_PROVIDER=auto

# Finnhub API Key (recommended for backend quotes/search/news and AI portfolio analysis)
# Sign up at https://finnhub.io to get a free API key
# Free tier: 60 API requests per minute
# Note: In Vite, environment variables must be prefixed with VITE_
FINNHUB_API_KEY=demo
VITE_FINNHUB_API_KEY=demo

# Optional Alpha Vantage API Key (only used when STOCK_API_PROVIDER=alphavantage
# or as a fallback if Finnhub is not configured and STOCK_API_KEY is real)
STOCK_API_KEY=

# OpenAI API Key
# Sign up at https://platform.openai.com to get an API key
# Required for AI portfolio analysis feature
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (optional, defaults to gpt-3.5-turbo)
# Options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
OPENAI_MODEL=gpt-3.5-turbo

# Database Configuration
DATABASE_URL="file:./dev.db"

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_change_in_production

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Frontend API URL (for Vite)
VITE_API_URL=http://localhost:3000/api/v1
