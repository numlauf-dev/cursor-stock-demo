# Finnhub API Key
# Sign up at https://finnhub.io to get a free API key
# Free tier: 60 API requests per minute
# Note: In Vite, environment variables must be prefixed with VITE_
VITE_FINNHUB_API_KEY=demo
FINNHUB_API_KEY=demo

# OpenAI API Key
# Sign up at https://platform.openai.com to get an API key
# Required for AI portfolio analysis feature
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (optional, defaults to gpt-3.5-turbo)
# Options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
OPENAI_MODEL=gpt-3.5-turbo

# Database Configuration
DATABASE_URL="file:./dev.db"

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_change_in_production

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Frontend API URL (for Vite)
VITE_API_URL=http://localhost:3000/api/v1
